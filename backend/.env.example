# Application
APP_NAME=IHMA Social Platform
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
DEBUG=false

# Database
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/social_platform

# JWT
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Telegram Bot
BOT_TOKEN=
WEBHOOK_URL=

# Superadmin
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=Admin@123456

# Muxlisa AI Voice (STT + TTS)
# Get your API key from https://service.muxlisa.uz
MUXLISA_API_KEY=your_muxlisa_api_key_here
MUXLISA_TTS_SPEAKER=0   # 0=female, 1=male
